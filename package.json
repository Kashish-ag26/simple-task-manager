    "@types/nodemailer": "^7.0.10",
    "@types/react-big-calendar": "^1.16.3",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.17",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "next": "14.2.29",
